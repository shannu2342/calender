### Server
PORT=5000
GOOGLE_TTS_API_KEY=

### Prokerala (keep these server-side only; never expose to frontend)
PROKERALA_CLIENT_ID=your_client_id_here
PROKERALA_CLIENT_SECRET=your_client_secret_here
# Do NOT set a static access token; backend fetches OAuth token automatically.
# Optional failover credentials (used when previous key hits quota/credit issues)
PROKERALA_CLIENT_ID_2=your_client_id_2_here
PROKERALA_CLIENT_SECRET_2=your_client_secret_2_here
PROKERALA_CLIENT_ID_3=your_client_id_3_here
PROKERALA_CLIENT_SECRET_3=your_client_secret_3_here
PROKERALA_CLIENT_ID_4=your_client_id_4_here
PROKERALA_CLIENT_SECRET_4=your_client_secret_4_here

# Start credential index (0-based). Use to test specific key locally.
# For localhost testing with only key #9, set to 8 (0-indexed).
# Leave empty or unset for random distribution.
PROKERALA_START_INDEX=

# OAuth 2.0 token endpoint (client_credentials)
PROKERALA_TOKEN_URL=https://api.prokerala.com/token

# API base URL
PROKERALA_BASE_URL=https://api.prokerala.com/v2

# Axios timeout for token + API requests
PROKERALA_TIMEOUT_MS=15000

# In-memory cache for Prokerala GET responses (helps avoid hitting 429 quickly)
# Set 0 to disable. Recommended production value: 300000-900000.
PROKERALA_CACHE_TTL_MS=300000

# Retry throttled upstream requests (429) with small incremental delay.
PROKERALA_RATE_LIMIT_RETRIES=2
PROKERALA_RATE_LIMIT_BACKOFF_MS=500

# Default timezone offset used when frontend sends only date/time (India is +05:30).
# You can also send tzOffset per request (e.g. "+05:30").
DEFAULT_TZ_OFFSET=+05:30

### Optional: override specific API paths (useful if Prokerala changes paths or you switch products)
PROKERALA_ENDPOINT_KUNDALI=/astrology/kundli/advanced
PROKERALA_ENDPOINT_MATCHMAKING=/astrology/kundli-matching
PROKERALA_ENDPOINT_MUHURAT=/astrology/auspicious-period
PROKERALA_ENDPOINT_PANCHANG=/astrology/panchang
PROKERALA_ENDPOINT_PANCHANG_ADVANCED=/astrology/panchang/advanced
PROKERALA_ENDPOINT_CHOGHADIYA=/astrology/choghadiya

# Optional add-ons. Keep disabled in production unless you need them,
# because each enabled feature adds extra Prokerala API calls.
PROKERALA_ENABLE_PANCHANG_ADVANCED=false
PROKERALA_ENABLE_CHOGHADIYA=false

# Optional: used to enrich Kundali with planet positions (if your Prokerala plan supports it)
PROKERALA_ENDPOINT_PLANET_POSITIONS=/astrology/planet-position

### Database Caching Configuration
# Cache TTL for panchang data in database (in days)
# Default: 30 days - recalculated daily so astronomical data remains accurate
PANCHANG_CACHE_TTL_DAYS=30

# Enable verbose database logging (useful for debugging)
# Default: false
DB_VERBOSE_LOGGING=false
